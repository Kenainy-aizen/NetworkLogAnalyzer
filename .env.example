# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# Base de données PostgreSQL
DB_PASSWORD=votre_mot_de_passe_db

# Email SMTP (exemple avec Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre.email@gmail.com
